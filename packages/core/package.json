{
  "name": "@actuarial-ts/core",
  "version": "0.1.0",
  "description": "Pure, zero-dependency P&C loss reserving engine for TypeScript: triangles, chain ladder, Mack, Bornhuetter-Ferguson, Cape Cod, Berquist-Sherman, tails, trend/on-level, ILF, diagnostics \u2014 validated against published actuarial literature.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yerromnitsuj/actng.git",
    "directory": "packages/core"
  },
  "keywords": [
    "actuarial",
    "reserving",
    "chain-ladder",
    "mack",
    "bornhuetter-ferguson",
    "cape-cod",
    "berquist-sherman",
    "loss-development",
    "triangle",
    "ibnr",
    "insurance",
    "property-casualty"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
