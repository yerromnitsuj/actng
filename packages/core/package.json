{
  "name": "@actuarial-ts/core",
  "version": "0.2.0",
  "description": "Pure, zero-dependency P&C loss reserving engine for TypeScript: triangles, chain ladder, Mack, Bornhuetter-Ferguson, Benktander, Cape Cod (Gluck decay), Munich chain ladder, Clark growth curves, frequency-severity, Berquist-Sherman, ULAE, discounting, tails, capping/ILF, trend/on-level, diagnostics, and a seeded stochastic layer (ODP bootstrap, Merz-Wuthrich one-year risk) — validated against published actuarial literature.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yerromnitsuj/actng.git",
    "directory": "packages/core"
  },
  "keywords": [
    "actuarial",
    "reserving",
    "chain-ladder",
    "mack",
    "bornhuetter-ferguson",
    "cape-cod",
    "berquist-sherman",
    "loss-development",
    "triangle",
    "ibnr",
    "insurance",
    "property-casualty",
    "odp-bootstrap",
    "merz-wuthrich",
    "munich-chain-ladder",
    "clark",
    "stochastic-reserving",
    "ulae",
    "discounting"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
