{
  "$ref": "#/definitions/triangle",
  "definitions": {
    "triangle": {
      "type": "object",
      "properties": {
        "interchangeVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "kind": {
          "type": "string",
          "const": "triangle"
        },
        "generator": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "name",
            "version"
          ],
          "additionalProperties": true
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": {}
        },
        "integrity": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$"
        },
        "triangle": {
          "type": "object",
          "properties": {
            "measure": {
              "anyOf": [
                {
                  "type": "string",
                  "enum": [
                    "paid",
                    "incurred",
                    "caseReserve",
                    "reportedCount",
                    "openCount",
                    "closedCount",
                    "closedWithPayCount",
                    "earnedPremium"
                  ]
                },
                {
                  "type": "string",
                  "pattern": "^custom:.+$"
                }
              ]
            },
            "cumulative": {
              "type": "boolean"
            },
            "originLengthMonths": {
              "type": "number",
              "enum": [
                12,
                6,
                3,
                1
              ]
            },
            "origins": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string",
                    "minLength": 1
                  },
                  "start": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                  }
                },
                "required": [
                  "label",
                  "start"
                ],
                "additionalProperties": true
              },
              "minItems": 1
            },
            "agesMonths": {
              "type": "array",
              "items": {
                "type": "integer",
                "exclusiveMinimum": 0
              },
              "minItems": 1
            },
            "values": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "number"
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              }
            },
            "valuesRef": {
              "type": "object",
              "properties": {
                "format": {
                  "type": "string",
                  "const": "arrow"
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "sha256": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "format",
                "path",
                "sha256"
              ],
              "additionalProperties": true
            },
            "valuationDate": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "basis": {
              "type": "object",
              "properties": {
                "grossNet": {
                  "type": "string",
                  "enum": [
                    "gross",
                    "net"
                  ]
                },
                "laeTreatment": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            },
            "units": {
              "type": "object",
              "properties": {
                "currency": {
                  "type": "string"
                },
                "scale": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              },
              "additionalProperties": true
            },
            "segment": {
              "type": "object",
              "properties": {
                "labels": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "labels"
              ],
              "additionalProperties": true
            }
          },
          "required": [
            "measure",
            "cumulative",
            "originLengthMonths",
            "origins",
            "agesMonths",
            "valuationDate"
          ],
          "additionalProperties": true
        }
      },
      "required": [
        "interchangeVersion",
        "kind",
        "generator",
        "createdAt",
        "integrity",
        "triangle"
      ],
      "additionalProperties": true
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
