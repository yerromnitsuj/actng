{
  "name": "actng",
  "private": true,
  "version": "1.0.0",
  "description": "ActNG: an AI-native actuarial reserving workbench",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run seed --workspace @actng/server -- --if-empty && concurrently -n server,web -c blue,magenta \"npm run dev --workspace @actng/server\" \"npm run dev --workspace @actng/web\"",
    "seed": "npm run seed --workspace @actng/server",
    "test": "npm run test --workspaces --if-present",
    "test:py": ".venv-interop/bin/pytest interop/python/tests interop/conformance/py interop/sidecar/tests -q",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "prepare": "npm run build -w @actuarial-ts/core -w @actuarial-ts/interchange -w @actuarial-ts/data -w @actuarial-ts/compliance -w @actuarial-ts/agents"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
