{
  "name": "actuarial-ts-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for the @actuarial-ts SDK (five published packages) and the actuarial-interchange interop layer; not itself published",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "test:py": ".venv-interop/bin/pytest interop/python/tests interop/conformance/py interop/sidecar/tests -q",
    "crosscheck:ci": "tsx interop/conformance/crosscheck-ci.mts",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "prepare": "npm run build -w @actuarial-ts/core -w @actuarial-ts/interchange -w @actuarial-ts/data -w @actuarial-ts/compliance -w @actuarial-ts/agents",
    "example": "npm run example -w @actuarial-ts/example-reserve-review",
    "example:cl-ts": "npm run example -w @actuarial-ts/example-chain-ladder-typescript",
    "example:cl-py": "npm run example -w @actuarial-ts/example-chain-ladder-python",
    "example:cl-r": "npm run example -w @actuarial-ts/example-chain-ladder-r",
    "example:cl-crosscheck": "npm run example -w @actuarial-ts/example-chain-ladder-crosscheck"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
